        <p class="contact-subtitle">
            Found a bug predicting pairings? Have a feature suggestion? 
            Fill out the form below and I'll get back to you.
        </p>

        <?php
        $form_error = '';
        $form_success = false;

        // Handle inline form submission (non-JS fallback)
        if ($_SERVER['REQUEST_METHOD'] === 'POST') {
            require_once __DIR__ . '/api/send-contact.php';
        }
        ?>

        <?php if ($form_error): ?>
        <div class="contact-alert error" id="form-alert" style="display: block;">
            <?= htmlspecialchars($form_error) ?>
        </div>
        <?php endif; ?>

        <?php if ($form_success): ?>
        <div class="contact-alert success" id="form-alert" style="display: block;">
            ✅ Your message has been sent. I'll get back to you as soon as possible.
        </div>
        <?php else: ?>
        <form class="contact-form" id="contact-form" method="POST">
            <div id="contact-form-fields">
            <div class="form-row">
                <div class="form-group">
                    <label for="name">Name <span class="required">*</span></label>
                    <input type="text" id="name" name="name" required
                           placeholder="Your name" maxlength="100">
                </div>
                <div class="form-group">
                    <label for="email">Email <span class="required">*</span></label>
                    <input type="email" id="email" name="email" required
                           placeholder="your@email.com" maxlength="200">
                </div>
            </div>

            <div class="form-group">
                <label for="tournament_url">Tournament URL</label>
                <input type="url" id="tournament_url" name="tournament_url"
                       placeholder="https://chess-results.com/tnrXXXXXX.aspx" maxlength="500">
            </div>

            <div class="form-group">
                <label for="message">Description <span class="required">*</span></label>
                <textarea id="message" name="message" required
                          placeholder="Describe the issue, feature request, or question..."
                          maxlength="5000"></textarea>
            </div>

            <!-- hCaptcha placeholder — enabled once keys are filled in config -->
            <?php if (defined('HCAPTCHA_SITE_KEY') && HCAPTCHA_SITE_KEY): ?>
            <div class="h-captcha" data-sitekey="<?= HCAPTCHA_SITE_KEY ?>"></div>
            <?php endif; ?>

            <div class="contact-alert" id="form-alert-dynamic" style="display:none; margin-bottom: 0.5rem;"></div>

            <button type="submit" class="submit-btn" id="submit-btn">
                Send Message
            </button>
            </div>
        </form>
        <?php endif; ?>

        <div class="contact-help">
            <h3>Need faster help?</h3>
            <p>
                If you're reporting a bug, please include the 
                <strong>tournament URL</strong> from chess-results.com so I can 
                investigate. For general questions, the description field is all I need.
            </p>
        </div>
    </main>

    <footer class="footer" style="text-align:center; padding: 1.5rem; color: var(--text-muted); font-size: 0.8rem;">
        © <?= date('Y') ?> ChessPairings — Predict Swiss-system pairings
    </footer>

    <?php if (defined('HCAPTCHA_SITE_KEY') && HCAPTCHA_SITE_KEY): ?>
    <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
    <?php if (defined('HCAPTCHA_SITE_KEY') && HCAPTCHA_SITE_KEY): ?>
    <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
    <?php endif; ?>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('contact-form');
            const btn = document.getElementById('submit-btn');
            const alertEl = document.getElementById('form-alert-dynamic');

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                btn.disabled = true;
                btn.textContent = 'Sending...';

                const formData = new FormData(form);

                try {
                    const resp = await fetch('/api/send-contact.php', {
                        method: 'POST',
                        body: formData,
                    });
                    const data = await resp.json();

                    if (data.success) {
                        form.style.display = 'none';
                        const msg = document.createElement('div');
                        msg.className = 'contact-alert success';
                        msg.style.display = 'block';
                        msg.textContent = '✅ Your message has been sent. I\'ll get back to you as soon as possible.';
                        form.parentNode.insertBefore(msg, form);
                    } else {
                        if (alertEl) {
                            alertEl.className = 'contact-alert error';
                            alertEl.style.display = 'block';
                            alertEl.textContent = data.error || 'Something went wrong. Please try again.';
                        }
                        btn.disabled = false;
                        btn.textContent = 'Send Message';
                    }
                } catch (err) {
                    btn.disabled = false;
                    btn.textContent = 'Send Message';
                    if (alertEl) {
                        alertEl.className = 'contact-alert error';
                        alertEl.style.display = 'block';
                        alertEl.textContent = 'Network error. Please check your connection and try again.';
                    }
                }
            });
        });
    </script>
</body>
</html>
