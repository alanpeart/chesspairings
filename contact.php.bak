        }

        .submit-btn:active {
            transform: scale(0.98);
        }

        .submit-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .contact-alert {
            padding: 1rem 1.25rem;
            border-radius: 8px;
            font-size: 0.9rem;
            line-height: 1.5;
            display: none;
        }

        .contact-alert.success {
            background: rgba(74, 222, 128, 0.1);
            border: 1px solid rgba(74, 222, 128, 0.3);
